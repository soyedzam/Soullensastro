---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages/aniversario.css';
---
<BaseLayout
  title={"Primer Aniversario · Soul Lens Studios · 2025"}
  description={"Un año construyendo presencias que importan. Primer aniversario de Soul Lens Studios — Mérida, Yucatán."}
  canonical={"https://soullensstudios.live/aniversario"}
  ogImage={"https://soullensstudios.live/og-image.png"}
  ogType={"website"}
  themeColor={"#0A0A0B"}
  robots={"index,follow"}>
<a class="wa-float" href="https://wa.me/5215644844928?text=Hola%20Soul%20Lens%2C%20vi%20su%20aniversario%20y%20me%20interesa%20trabajar%20juntos." target="_blank" rel="noopener">
  <svg viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.103 1.523 5.824L.057 23.882a.5.5 0 00.613.613l6.058-1.466A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.01-1.373l-.36-.213-3.728.902.917-3.637-.234-.373A9.818 9.818 0 1112 21.818z"/></svg>
  <span class="wa-float-txt">Escríbenos →</span>
</a>

<header>
  <div class="nav-inner">
    <a href="/" class="brand">soul<span class="lens">lens</span><span class="st">studios</span></a>
    <a href="/" class="nav-back">← Volver al sitio</a>
  </div>
</header>

<main>

<!-- HERO -->
<section class="aniv-hero">
  <div class="aniv-year" aria-hidden="true">2025</div>
  <div class="aniv-badge">🎂 Primer Aniversario · Soul Lens Studios</div>
  <h1 class="aniv-h1">Un año.<br><span class="aniv-mark">Muchas marcas.</span><br>Un solo propósito.</h1>
  <p class="aniv-sub">Construimos presencias que hacen que las marcas sean elegidas una y otra vez. Este es solo el comienzo.</p>
  <div class="scroll-hint">Explora el año</div>
</section>

<!-- STATS -->
<section class="stats-sec">
  <div class="wrap">
    <div class="stats-grid">
      <div><div class="stat-n">+10</div><div class="stat-l">Proyectos de alto perfil</div></div>
      <div><div class="stat-n">3</div><div class="stat-l">Mercados premium</div></div>
      <div><div class="stat-n">2</div><div class="stat-l">Países · MX · US</div></div>
      <div><div class="stat-n">5.0</div><div class="stat-l">★ Rating Google</div></div>
      <div><div class="stat-n">22</div><div class="stat-l">Reseñas verificadas</div></div>
      <div><div class="stat-n">∞</div><div class="stat-l">Siguiente capítulo</div></div>
    </div>
  </div>
</section>

<!-- VIDEOS -->
<section class="vids-aniv">
  <div class="wrap">
    <h2>Lo que construimos en <span style="color:var(--et)">2025</span></h2>
    <p class="sub">Del primer proyecto al Foro AMPI con 1,200 personas. Este año fue de todo.</p>

    <div class="vid-row">
      <!-- Smart Pass / Aniversario TikTok -->
      <a class="av-card" href="https://www.tiktok.com/@soullensstudios/video/7604589462869380353" target="_blank" rel="noopener" aria-label="Smart Pass en TikTok">
        <div class="av-card-bg"><div class="brand-logo">Smart Pass™</div><div class="brand-tag">Activo digital premium</div></div>
        <div class="av-overlay">
          <div class="av-play"><svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          <div class="av-meta"><div class="lbl">Smart Pass</div><div class="ttl">Tu presencia digital trabajando 24/7</div></div>
        </div>
      </a>
      <!-- Estrategia TikTok -->
      <a class="av-card" href="https://www.tiktok.com/@soullensstudios/video/7604963681851542792" target="_blank" rel="noopener" aria-label="Estrategia Soul Lens en TikTok">
        <div class="av-card-bg" style="background:linear-gradient(145deg,#0A0A0B,#100A20)"><div class="brand-logo">Estrategia™</div><div class="brand-tag">Sistemas que convierten</div></div>
        <div class="av-overlay">
          <div class="av-play"><svg viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          <div class="av-meta"><div class="lbl">Soul Lens</div><div class="ttl">La estrategia detrás de cada activo</div></div>
        </div>
      </a>
    </div>

    <div class="vid-row single">
      <!-- Soul Stage YouTube -->
      <div class="av-card wide" onclick="openY('Bxk_HCdR40E')" role="button" aria-label="Soul Stage YouTube">
        <img class="yt-thumb" src="https://img.youtube.com/vi/Bxk_HCdR40E/maxresdefault.jpg" alt="Soul Stage — Estudio de producción Soul Lens Studios Mérida" loading="lazy" width="1280" height="720">
        <div class="av-overlay">
          <div class="av-play yt-play"><svg viewBox="0 0 24 24" style="fill:#fff;margin-left:3px"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          <div class="av-meta"><div class="lbl">Soul Stage</div><div class="ttl">El estudio que transforma tu producción</div></div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Modal YouTube -->
<div id="ym" onclick="closeY(event)" style="display:none;position:fixed;inset:0;z-index:9500;background:rgba(0,0,0,.92);align-items:center;justify-content:center;padding:20px">
  <div style="position:relative;width:100%;max-width:900px;aspect-ratio:16/9;border-radius:14px;overflow:hidden">
    <button onclick="closeY()" style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:28px;cursor:pointer">✕</button>
    <iframe id="yif" src="" allow="autoplay;fullscreen" allowfullscreen style="width:100%;height:100%;border:none"></iframe>
  </div>
</div>

<!-- MISSION -->
<section class="mission">
  <div class="wrap">
    <h2>El año 2 empieza <span style="color:var(--et)">ahora.</span></h2>
    <p>Si en un año construimos esto, imagina lo que viene. Únete a las marcas que ya eligieron trabajar diferente.</p>
    <a class="btn-main" href="/pulse">Diagnosticar mi marca gratis →</a>
  </div>
</section>

</main>

<footer>
  <div class="wrap">
    <div class="foot-brand">Designed by Soul Lens · Powered by Xplorers Startups · Mérida, Yucatán 2025</div>
  </div>
</footer>

<script is:inline>
function openY(id){var m=document.getElementById("ym");m.style.display="flex";document.getElementById("yif").src="https://www.youtube-nocookie.com/embed/"+id+"?autoplay=1&rel=0";}
function closeY(e){if(!e||e.target.id==="ym"||e.target.tagName==="BUTTON"){var m=document.getElementById("ym");m.style.display="none";document.getElementById("yif").src="";}}
document.addEventListener("keydown",function(e){if(e.key==="Escape")closeY();});
</script>
</BaseLayout>
