/* ---- aperture canvas (signature: el lente) ---- */
(function(){
  const c=document.getElementById('aperture');if(!c)return;
  const rm=window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const ctx=c.getContext('2d');let w,h,dpr,t=0,mx=.78,my=.5,tmx=.78,tmy=.5;
  function size(){dpr=Math.min(devicePixelRatio||1,2);w=c.clientWidth;h=c.clientHeight;
    c.width=w*dpr;h=c.clientHeight;c.height=h*dpr;ctx.setTransform(dpr,0,0,dpr,0,0);}
  size();addEventListener('resize',size);
  addEventListener('pointermove',e=>{tmx=e.clientX/innerWidth;tmy=e.clientY/innerHeight;},{passive:true});
  // particle field
  const N=rm?60:120;const ps=[];for(let i=0;i<N;i++)ps.push({a:Math.random()*Math.PI*2,r:60+Math.random()*Math.max(w,h)*.55,s:.0008+Math.random()*.0016,z:Math.random()});
  function draw(){
    t+=1;mx+=(tmx-mx)*.04;my+=(tmy-my)*.04;
    const cx=w*(.62+(mx-.5)*.10),cy=h*(.5+(my-.5)*.10);
    ctx.clearRect(0,0,w,h);
    // aperture rings
    const base=Math.min(w,h)*.30;const breathe=Math.sin(t*0.012)*0.06+1;
    for(let i=0;i<5;i++){
      const rr=base*breathe*(1+i*.42);
      ctx.beginPath();ctx.arc(cx,cy,rr,0,Math.PI*2);
      ctx.strokeStyle='rgba(6,83,255,'+(0.30-i*0.05)+')';ctx.lineWidth=i===0?1.6:1;ctx.stroke();
    }
    // aperture blades (hexagon-ish glow)
    const blades=7,ar=base*breathe*.92;
    ctx.save();ctx.translate(cx,cy);ctx.rotate(t*0.0012);
    ctx.beginPath();
    for(let i=0;i<=blades;i++){const a=i/blades*Math.PI*2;ctx.lineTo(Math.cos(a)*ar,Math.sin(a)*ar);}
    const g=ctx.createRadialGradient(0,0,ar*.2,0,0,ar);
    g.addColorStop(0,'rgba(6,83,255,0.22)');g.addColorStop(.7,'rgba(68,138,255,0.05)');g.addColorStop(1,'rgba(6,83,255,0)');
    ctx.fillStyle=g;ctx.fill();
    ctx.strokeStyle='rgba(68,138,255,0.35)';ctx.lineWidth=1;ctx.stroke();
    ctx.restore();
    // core glow
    const cg=ctx.createRadialGradient(cx,cy,0,cx,cy,base*.6);
    cg.addColorStop(0,'rgba(68,138,255,0.16)');cg.addColorStop(1,'rgba(6,83,255,0)');
    ctx.fillStyle=cg;ctx.beginPath();ctx.arc(cx,cy,base*.6,0,Math.PI*2);ctx.fill();
    // particles orbiting
    for(const p of ps){p.a+=p.s;const x=cx+Math.cos(p.a)*p.r,y=cy+Math.sin(p.a)*p.r*.62;
      ctx.beginPath();ctx.arc(x,y,p.z*1.6+.4,0,Math.PI*2);
      ctx.fillStyle='rgba(242,243,245,'+(.10+p.z*.22)+')';ctx.fill();}
    if(!rm)requestAnimationFrame(draw);else{/* draw one static frame */}
  }
  draw();
})();
